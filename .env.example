OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Use "memory" for a zero-dependency demo or "postgres" for durable workflows.
PERSISTENCE_BACKEND=memory
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/enterprise_learning
POSTGRES_SCHEMA=learning_copilot
POSTGRES_POOL_MAX=10
# Separate session pool: lock holders never consume checkpoint/query capacity.
POSTGRES_WORKFLOW_LOCK_POOL_MAX=5
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_STATEMENT_TIMEOUT_MS=30000
POSTGRES_WORKFLOW_LOCK_TIMEOUT_MS=5000
